    {
      "parameters": {
        "jsCode": "let finalItems = [];\n\n// Lấy toàn bộ đầu vào từ Node HTML và toàn bộ mã từ Node Excel\nlet inputItems = $input.all(); \nlet sheetItems = $('Get row(s) in sheet').all();\n\n// Lặp qua TỪNG luồng dữ liệu (Từng mã chứng khoán: VCI, VHC, FPT...)\nfor (let index = 0; index < inputItems.length; index++) {\n    \n    // Lấy mảng bài báo của mã chứng khoán hiện tại\n    let titles = inputItems[index].json.article_title || [];\n    let urls = inputItems[index].json.article_url || [];\n    let dates = inputItems[index].json.article_date || [];\n    \n    // Tuyệt chiêu Map dữ liệu: HTML số mấy thì lấy Ticker ở dòng số bấy nhiêu!\n    let ticker = sheetItems[index] ? sheetItems[index].json.ticker : \"UNKNOWN\";\n\n    // Khâu các phần tử của riêng mã chứng khoán này lại với nhau\n    let max_length = Math.max(titles.length, urls.length);\n    for (let i = 0; i < max_length; i++) {\n        if(titles[i]) {\n            let raw_url = urls[i] ? urls[i].trim() : \"\";\n            let full_url = raw_url.startsWith(\"http\") ? raw_url : \"https://cafef.vn\" + raw_url;\n          \n            finalItems.push({\n                json: {\n                    ticker: ticker,\n                    article_title: titles[i],\n                    article_url: full_url,\n                    article_date: dates[i]\n                }\n            });\n        }\n    }\n}\n\n// Trả về danh sách tổng hợp của TẤT CẢ các mã\nreturn finalItems;"
      },
