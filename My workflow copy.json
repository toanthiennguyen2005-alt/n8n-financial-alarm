    {
      "parameters": {
        "jsCode": "// 1. Trích xuất tất cả các tiêu đề từ luồng dữ liệu trước đó\nlet titles = $input.all().map(item => item.json.article_title);\n\n// 2. Gộp các tiêu đề lại thành 1 đoạn văn bản, mỗi tiêu đề nằm trên 1 dòng\nlet combinedTitles = titles.join(\"\\n\");\n\n// 3. Trả về đúng 1 khối dữ liệu duy nhất chứa đoạn văn bản đó\nreturn [{\n    json: {\n        aggregated_titles: combinedTitles\n    }\n}];"
      },
