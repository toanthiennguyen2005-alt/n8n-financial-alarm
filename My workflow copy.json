    {
      "parameters": {
        "jsCode": "// 1. Kéo thả lại đường dẫn chứa kết quả từ Gemini vào biến này nhé:\nlet aiResponse = $input.first().json.candidates[0].content.parts[0].text; \n\n// 2. Dùng split và join để gọt sạch dấu nháy (Không dùng Regex nữa)\nlet cleanText = aiResponse;\nif (cleanText) {\n    cleanText = cleanText.split(\"```json\").join(\"\");\n    cleanText = cleanText.split(\"```\").join(\"\");\n    cleanText = cleanText.trim();\n}\n\n// 3. Dịch chuỗi văn bản thành Mảng dữ liệu thật\nlet dataArray = JSON.parse(cleanText);\n\n// 4. Bọc lại thành cấu trúc Items để đổ từng dòng vào PostgreSQL\nlet finalItems = dataArray.map(article => {\n    return { json: article };\n});\n\nreturn finalItems;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2080,
